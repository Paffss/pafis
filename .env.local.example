# Path to the directory containing your kubernetes manifests
# Run `npm run fetch:minikube` to auto-populate this from a running minikube cluster
PAFIS_BASE=./data

# Prometheus URL (optional — app works without it, cost panel will be disabled)
PROMETHEUS_URL=http://localhost:9090

# AI Provider: "anthropic" (default) or "ollama"
AI_PROVIDER=anthropic

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Ollama settings (only needed if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# OLLAMA_USER=
# OLLAMA_PASS=
